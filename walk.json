{
  "name": "crab_travel",
  "baseUrl": "https://crab.travel",
  "routes": [
    "/",
    "/about",
    "/roadmap",
    "/privacy",
    "/terms",
    "/contact",
    "/crab-animations",
    "/health",
    "/sitemap.xml",
    "/robots.txt",
    "/timeshare/",
    { "path": "/timeshare/catalog", "expectText": "Interval International" },
    { "path": "/timeshare/catalog/resort/AVR", "expectText": "Acadia Village" }
  ],
  "checks": {
    "noBrokenImages": true,
    "noConsoleErrors": true,
    "no5xx": true,
    "no4xx": false
  },
  "viewport": { "width": 1440, "height": 900 },
  "screenshots": true
}
